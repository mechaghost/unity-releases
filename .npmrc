# @visx/* still declares React 18 as a peer dep, but the libraries work
# fine against React 19. Without this flag, Railway's `npm ci` step
# (Railpack/npm 10) refuses to install because of the peer-dep mismatch.
# See: cron-all redeploy on 2026-05-17 — build failed with ERESOLVE.
legacy-peer-deps=true
